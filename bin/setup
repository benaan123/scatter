#!/usr/bin/env bash
#
# setup — Add shell aliases and PATH for the command station
#
# Usage:
#   bin/setup          Auto-detect shell, add aliases
#   bin/setup --undo   Remove aliases
#
set -euo pipefail

# Check dependencies
if ! command -v tmux &>/dev/null; then
  echo "Warning: tmux is not installed. Scatter requires tmux." >&2
fi
if ! command -v claude &>/dev/null; then
  echo "Warning: claude CLI is not installed. Scatter requires Claude Code." >&2
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MARKER="# scatter"

# Detect shell config file
if [[ -n "${ZSH_VERSION:-}" ]] || [[ "$SHELL" == */zsh ]]; then
    RC_FILE="$HOME/.zshrc"
elif [[ -n "${BASH_VERSION:-}" ]] || [[ "$SHELL" == */bash ]]; then
    RC_FILE="$HOME/.bashrc"
else
    echo "Unsupported shell: $SHELL" >&2
    echo "Manually add the following to your shell config:" >&2
    echo "" >&2
    echo "  alias scatter='tmux new-session -s command-station -n commander \"claude --agent scatter\" 2>/dev/null || tmux attach -t command-station'" >&2
    echo "  export PATH=\"$SCRIPT_DIR:\$PATH\"" >&2
    exit 1
fi

BLOCK="$MARKER
alias scatter='tmux new-session -s command-station -n commander \"claude --agent scatter\" 2>/dev/null || tmux attach -t command-station'
export PATH=\"$SCRIPT_DIR:\$PATH\"
$MARKER end"

if [[ "${1:-}" == "--undo" ]]; then
    if grep -q "$MARKER" "$RC_FILE" 2>/dev/null; then
        if sed --version 2>/dev/null | grep -q GNU; then
            sed -i "/$MARKER/,/$MARKER end/d" "$RC_FILE"
        else
            sed -i '' "/$MARKER/,/$MARKER end/d" "$RC_FILE"
        fi
        echo "Removed command station aliases from $RC_FILE"
        echo "Run: source $RC_FILE"
    else
        echo "Nothing to remove — no aliases found in $RC_FILE"
    fi
    exit 0
fi

# Idempotent: skip if already installed
if grep -q "$MARKER" "$RC_FILE" 2>/dev/null; then
    echo "Already installed in $RC_FILE"
    echo ""
    echo "  scatter   — launch or attach to the command station"
    echo "  station   — monitor teams (list, capture, status, sweep)"
    echo ""
    echo "Run: source $RC_FILE  (or open a new terminal)"
    exit 0
fi

echo "" >> "$RC_FILE"
echo "$BLOCK" >> "$RC_FILE"

echo "Added to $RC_FILE:"
echo ""
echo "  scatter   — launch or attach to the command station"
echo "  station   — monitor teams (list, capture, status, sweep)"
echo ""
echo "Run: source $RC_FILE  (or open a new terminal)"
