#!/usr/bin/env bash
#
# station — Monitor and manage team lead windows + panes in the Scatter command station
#
# Usage:
#   station list                      List all windows and their panes
#   station capture <team-name>       Capture a team lead's screen (from its window)
#   station capture-all               Capture all team lead screens
#   station kill <team-name>          Kill team lead window + its mirror pane
#   station cleanup <team-name>       Kill team + remove its git worktree
#   station worktrees <repo-path>     List all git worktrees for a repo
#   station layout                    Re-tile window 0 overview panes
#   station registry                  List all projects/repos from station.toml
#   station registry --resolve <name> Resolve project/tag to repo paths
#   station dashboard                 Combined overview (registry + teams + journal)

set -euo pipefail

SESSION="${TMUX_SESSION:-command-station}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
STATION_TOML="${SCRIPT_DIR}/../station.toml"

# --- Persistent ledger ---
LEDGER_DIR="${HOME}/.local/share/scatter"
LEDGER="${LEDGER_DIR}/ledger.jsonl"

# --- JSON escaping helper ---
json_escape() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g' | tr -d '\n'; }

ledger_append() {
    local event="$1" team="$2"
    shift 2
    mkdir -p "$LEDGER_DIR"
    local extra=""
    [[ $# -gt 0 ]] && extra="$*"
    printf '{"ts":"%s","event":"%s","team":"%s"%s}\n' \
      "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$(json_escape "$event")" "$(json_escape "$team")" "$extra" >> "$LEDGER"
}

require_tmux() {
    if ! tmux has-session -t "$SESSION" 2>/dev/null; then
        echo "Error: tmux session '$SESSION' not found." >&2
        echo "Start one with: tmux new-session -s $SESSION" >&2
        exit 1
    fi
}

# Find a pane by title across ALL windows in the session
find_pane_by_title() {
    local target="$1"
    tmux list-panes -s -t "$SESSION" -F '#{pane_id} #{pane_title}' 2>/dev/null | while read -r id title; do
        if [[ "$title" == "$target" ]]; then
            echo "$id"
            break
        fi
    done
}

# Find a window by name
find_window_by_name() {
    local target="$1"
    tmux list-windows -t "$SESSION" -F '#{window_id} #{window_name}' 2>/dev/null | while read -r id name; do
        if [[ "$name" == "$target" ]]; then
            echo "$id"
            break
        fi
    done
}

cmd_list() {
    echo "Command Station: ${SESSION}"
    echo ""

    tmux list-windows -t "$SESSION" -F '#{window_index}|#{window_name}|#{window_active}' 2>/dev/null | while IFS='|' read -r widx wname wactive; do
        if [[ "$wactive" == "1" ]]; then
            marker="*"
        else
            marker=" "
        fi

        if [[ "$widx" == "0" ]]; then
            echo "${marker} Window ${widx}: ${wname} (dashboard)"
        else
            echo "${marker} Window ${widx}: ${wname}"
        fi

        # List panes in this window
        tmux list-panes -t "${SESSION}:${widx}" -F '    #{pane_index}|#{pane_title}|#{pane_pid}|#{pane_current_command}|#{pane_width}x#{pane_height}|#{pane_current_path}' 2>/dev/null | while IFS='|' read -r pidx ptitle ppid pcmd psize pcwd; do
            if kill -0 "$ppid" 2>/dev/null; then
                status="●"
            else
                status="○"
            fi

            printf "  %s  %-22s  (%s)  [%s]\n" "$status" "$ptitle" "$pcmd" "$psize"
        done
        echo ""
    done
}

cmd_capture() {
    local target="$1"

    # First try: find the team lead pane in its own window (the real session)
    local pane_id=""
    pane_id=$(find_pane_by_title "$target")

    if [[ -z "$pane_id" ]]; then
        echo "No pane found with title: $target" >&2
        echo "Available team windows:" >&2
        tmux list-windows -t "$SESSION" -F '  #{window_name}' 2>/dev/null >&2
        return 1
    fi

    echo "=== $target ==="
    tmux capture-pane -t "$pane_id" -p -e 2>/dev/null
    echo "=== end ==="
}

cmd_capture_all() {
    # Capture team lead panes from their dedicated windows (not the mirrors)
    # Skip window 0 (that's the dashboard with mirrors)
    tmux list-windows -t "$SESSION" -F '#{window_index}|#{window_name}' 2>/dev/null | while IFS='|' read -r widx wname; do
        if [[ "$widx" == "0" ]]; then
            continue
        fi

        # Get the first pane in this window (the team lead)
        local pane_id
        pane_id=$(tmux list-panes -t "${SESSION}:${widx}" -F '#{pane_id}' 2>/dev/null | head -1)

        if [[ -n "$pane_id" ]]; then
            echo "=== [$wname] ==="
            tmux capture-pane -t "$pane_id" -p -e 2>/dev/null
            echo ""
        fi
    done
}

cmd_kill() {
    local target="$1"

    # Kill the team lead's dedicated window
    local window_id
    window_id=$(find_window_by_name "$target")

    if [[ -n "$window_id" ]]; then
        tmux kill-window -t "$window_id" 2>/dev/null
        echo "Killed window: $target"
    fi

    # Also kill the mirror pane in window 0
    local mirror_id
    mirror_id=$(find_pane_by_title "${target}-mirror")
    if [[ -n "$mirror_id" ]]; then
        tmux kill-pane -t "$mirror_id" 2>/dev/null
        echo "Killed mirror pane"
    fi

    ledger_append "team_kill" "$target"
}

cmd_cleanup() {
    local target="$1"

    # Get cwd from the team lead's window before killing
    local pane_cwd=""
    local pane_id
    pane_id=$(find_pane_by_title "$target")
    if [[ -n "$pane_id" ]]; then
        pane_cwd=$(tmux display-message -t "$pane_id" -p '#{pane_current_path}' 2>/dev/null)
    fi

    # Kill window + mirror
    cmd_kill "$target"

    # Remove worktree if applicable
    if [[ -n "$pane_cwd" && "$pane_cwd" == *"/.worktrees/"* ]]; then
        local main_repo="${pane_cwd%%/.worktrees/*}"
        if git -C "$main_repo" worktree list 2>/dev/null | grep -q "$pane_cwd"; then
            git -C "$main_repo" worktree remove "$pane_cwd" --force 2>/dev/null && \
                echo "Removed worktree: $pane_cwd" || \
                echo "Warning: could not remove worktree at $pane_cwd" >&2
        fi
    fi
}

cmd_worktrees() {
    local repo_path="${1:-.}"
    repo_path=$(cd "$repo_path" 2>/dev/null && pwd || echo "$repo_path")

    if ! git -C "$repo_path" rev-parse --is-inside-work-tree &>/dev/null; then
        echo "Not a git repo: $repo_path" >&2
        return 1
    fi

    echo "Worktrees for $(basename "$repo_path"):"
    echo ""
    git -C "$repo_path" worktree list --porcelain | while read -r line; do
        case "$line" in
            "worktree "*)
                wt_path="${line#worktree }"
                ;;
            "branch "*)
                branch="${line#branch refs/heads/}"
                printf "  %s\n    branch: %s\n\n" "$wt_path" "$branch"
                ;;
            "HEAD "*)
                ;;
            "detached")
                printf "  %s\n    (detached HEAD)\n\n" "$wt_path"
                ;;
        esac
    done
}

cmd_layout() {
    # Re-tile just window 0 (the dashboard)
    tmux select-layout -t "${SESSION}:0" main-horizontal 2>/dev/null || \
        tmux select-layout -t "${SESSION}:0" tiled 2>/dev/null
    echo "Re-tiled dashboard layout"
}

STATUS_DIR="/tmp/scatter-status"

cmd_status() {
    local target="${1:-}"
    if [[ -n "$target" ]]; then
        # Single team status
        if [[ -f "${STATUS_DIR}/${target}" ]]; then
            echo "${target}: $(cat "${STATUS_DIR}/${target}")"
        else
            echo "${target}: unknown (no status file)"
        fi
    else
        # All teams
        if [[ -d "$STATUS_DIR" ]] && ls "$STATUS_DIR"/* &>/dev/null; then
            for f in "$STATUS_DIR"/*; do
                local name=$(basename "$f")
                echo "${name}: $(cat "$f")"
            done
        else
            echo "No team status files found"
        fi
    fi
}

cmd_sweep() {
    # Clean up all completed teams — kill panes, remove worktrees, clear status
    local swept=0
    if [[ -d "$STATUS_DIR" ]] && ls "$STATUS_DIR"/* &>/dev/null; then
        for f in "$STATUS_DIR"/*; do
            local name=$(basename "$f")
            local state=$(cat "$f")
            if [[ "$state" == done:* ]]; then
                echo "Sweeping $name ($state)..."
                cmd_cleanup "$name" 2>/dev/null
                ledger_append "team_swept" "$name"
                rm -f "$f"
                swept=$((swept + 1))
            fi
        done
    fi
    if [[ $swept -eq 0 ]]; then
        echo "No completed teams to sweep"
    else
        echo "Swept $swept team(s)"
        cmd_layout 2>/dev/null
    fi
}

cmd_registry() {
    if [[ ! -f "$STATION_TOML" ]]; then
        echo "No station.toml found at $STATION_TOML" >&2
        return 1
    fi

    local resolve="${1:-}"
    local current_project="" display_name="" vault_path="" tags=""
    local current_repo="" repo_path="" repo_desc=""

    if [[ -n "$resolve" ]]; then
        # Resolve mode: find repos matching project name or tag (deduplicated)
        local -a found_paths=()
        local found=0
        while IFS= read -r line; do
            line="${line%%#*}"  # strip comments
            [[ -z "${line// /}" ]] && continue
            if [[ "$line" =~ ^\[projects\.([a-zA-Z0-9_-]+)\.repos\.([a-zA-Z0-9_-]+)\] ]]; then
                current_project="${BASH_REMATCH[1]}"
                current_repo="${BASH_REMATCH[2]}"
            elif [[ "$line" =~ ^\[projects\.([a-zA-Z0-9_-]+)\] ]]; then
                current_project="${BASH_REMATCH[1]}"
                current_repo=""
            elif [[ -n "$current_repo" && "$line" =~ ^path\ *=\ *\"(.+)\" ]]; then
                repo_path="${BASH_REMATCH[1]}"
                repo_path="${repo_path/#\~/$HOME}"
                if [[ "$current_project" == *"$resolve"* || "$current_repo" == *"$resolve"* ]]; then
                    # Deduplicate
                    local already=0
                    for p in "${found_paths[@]+"${found_paths[@]}"}"; do
                        [[ "$p" == "$repo_path" ]] && already=1 && break
                    done
                    if [[ $already -eq 0 ]]; then
                        found_paths+=("$repo_path")
                        echo "$repo_path"
                        found=1
                    fi
                fi
            elif [[ -z "$current_repo" && "$line" =~ ^tags\ *=\ *\[(.+)\] ]]; then
                local tag_str="${BASH_REMATCH[1]}"
                if [[ "$tag_str" == *"\"$resolve\""* ]]; then
                    # Print all repos for this project
                    local match_project="$current_project"
                    while IFS= read -r rline; do
                        rline="${rline%%#*}"
                        if [[ "$rline" =~ ^\[projects\.${match_project}\.repos\. ]]; then
                            :
                        elif [[ "$rline" =~ ^\[projects\. && ! "$rline" =~ ^\[projects\.${match_project} ]]; then
                            break
                        elif [[ "$rline" =~ ^path\ *=\ *\"(.+)\" ]]; then
                            local rp="${BASH_REMATCH[1]}"
                            rp="${rp/#\~/$HOME}"
                            local dup=0
                            for p in "${found_paths[@]+"${found_paths[@]}"}"; do
                                [[ "$p" == "$rp" ]] && dup=1 && break
                            done
                            if [[ $dup -eq 0 ]]; then
                                found_paths+=("$rp")
                                echo "$rp"
                                found=1
                            fi
                        fi
                    done < "$STATION_TOML"
                fi
            fi
        done < "$STATION_TOML"
        [[ $found -eq 0 ]] && echo "No repos found matching: $resolve" >&2 && return 1
        return 0
    fi

    # Pretty-print mode
    echo "╔══ Project Registry ══╗"
    echo ""
    while IFS= read -r line; do
        line="${line%%#*}"
        [[ -z "${line// /}" ]] && continue
        if [[ "$line" =~ ^\[projects\.([a-zA-Z0-9_-]+)\.repos\.([a-zA-Z0-9_-]+)\] ]]; then
            current_repo="${BASH_REMATCH[2]}"
        elif [[ "$line" =~ ^\[projects\.([a-zA-Z0-9_-]+)\] ]]; then
            [[ -n "$current_project" ]] && echo ""
            current_project="${BASH_REMATCH[1]}"
            current_repo=""
            display_name="" vault_path="" tags=""
        elif [[ "$line" =~ ^display_name\ *=\ *\"(.+)\" ]]; then
            display_name="${BASH_REMATCH[1]}"
            echo "▸ $display_name ($current_project)"
        elif [[ "$line" =~ ^vault_path\ *=\ *\"(.+)\" ]]; then
            vault_path="${BASH_REMATCH[1]}"
            echo "  vault: $vault_path"
        elif [[ "$line" =~ ^tags\ *=\ *\[(.+)\] ]]; then
            tags="${BASH_REMATCH[1]}"
            echo "  tags:  $tags"
        elif [[ -n "$current_repo" && "$line" =~ ^path\ *=\ *\"(.+)\" ]]; then
            echo "  ├─ $current_repo: ${BASH_REMATCH[1]}"
        elif [[ -n "$current_repo" && "$line" =~ ^description\ *=\ *\"(.+)\" ]]; then
            echo "  │  ${BASH_REMATCH[1]}"
        fi
    done < "$STATION_TOML"
    echo ""
}

cmd_dashboard() {
    echo "╔══ Scatter — Command Station ══╗"
    echo ""

    # Registry summary
    echo "── Registry ──"
    if [[ -f "$STATION_TOML" ]]; then
        local project_count=0 repo_count=0
        while IFS= read -r line; do
            if [[ "$line" =~ ^\[projects\.([a-zA-Z0-9_-]+)\.repos\. ]]; then
                repo_count=$((repo_count + 1))
            elif [[ "$line" =~ ^\[projects\.([a-zA-Z0-9_-]+)\]$ ]]; then
                project_count=$((project_count + 1))
            fi
        done < "$STATION_TOML"
        echo "  $project_count projects, $repo_count repos registered"

        # List project names
        while IFS= read -r line; do
            if [[ "$line" =~ ^display_name\ *=\ *\"(.+)\" ]]; then
                echo "  • ${BASH_REMATCH[1]}"
            fi
        done < "$STATION_TOML"
    else
        echo "  (no station.toml found)"
    fi
    echo ""

    # Active teams
    echo "── Active Teams ──"
    cmd_status
    echo ""

    # Recent journal
    echo "── Recent Journal ──"
    local vault_bin="${SCRIPT_DIR}/../bin/vault"
    if [[ -x "$vault_bin" ]]; then
        "$vault_bin" status all 2>/dev/null || echo "  (vault status unavailable)"
    else
        echo "  (bin/vault not installed)"
    fi
}

cmd_resume() {
    if [[ ! -f "$LEDGER" ]]; then
        echo "No session history found."
        return 0
    fi

    echo "╔══ Session Resume ══╗"
    echo ""

    # Build team state from ledger: last event per team
    # Output format: team|event|ts|extra fields
    local -A team_event team_ts team_repo team_branch team_project team_exit
    local -a team_order=()

    while IFS= read -r line; do
        local evt team ts
        evt=$(echo "$line" | sed -n 's/.*"event":"\([^"]*\)".*/\1/p')
        team=$(echo "$line" | sed -n 's/.*"team":"\([^"]*\)".*/\1/p')
        ts=$(echo "$line" | sed -n 's/.*"ts":"\([^"]*\)".*/\1/p')

        [[ -z "$team" ]] && continue

        # Track order of first appearance
        if [[ -z "${team_event[$team]+x}" ]]; then
            team_order+=("$team")
        fi

        team_event[$team]="$evt"
        team_ts[$team]="$ts"

        # Extract spawn metadata
        if [[ "$evt" == "team_spawn" ]]; then
            local repo branch project
            repo=$(echo "$line" | sed -n 's/.*"repo":"\([^"]*\)".*/\1/p')
            branch=$(echo "$line" | sed -n 's/.*"branch":"\([^"]*\)".*/\1/p')
            project=$(echo "$line" | sed -n 's/.*"project":"\([^"]*\)".*/\1/p')
            team_repo[$team]="$repo"
            team_branch[$team]="$branch"
            team_project[$team]="$project"
        fi

        if [[ "$evt" == "team_done" ]]; then
            local exit_code
            exit_code=$(echo "$line" | sed -n 's/.*"exit_code":\([0-9]*\).*/\1/p')
            team_exit[$team]="$exit_code"
        fi
    done < "$LEDGER"

    # Categorize teams
    local -a running=() completed=() attention=() merged=()

    for team in "${team_order[@]}"; do
        local evt="${team_event[$team]}"
        case "$evt" in
            team_spawn)
                # Check if tmux pane still alive
                local pane_id
                pane_id=$(find_pane_by_title "$team" 2>/dev/null || true)
                if [[ -n "$pane_id" ]]; then
                    running+=("$team")
                else
                    attention+=("$team")
                fi
                ;;
            team_done)
                completed+=("$team")
                ;;
            team_merged)
                merged+=("$team")
                ;;
            team_swept|team_kill)
                # Already cleaned up, skip
                ;;
        esac
    done

    # Display sections
    if [[ ${#running[@]} -gt 0 ]]; then
        echo "── Still Running ──"
        for team in "${running[@]}"; do
            local label="$team"
            [[ -n "${team_project[$team]:-}" ]] && label="$team [${team_project[$team]}]"
            echo "  $label"
            [[ -n "${team_branch[$team]:-}" ]] && echo "    branch: ${team_branch[$team]}"
            [[ -n "${team_repo[$team]:-}" ]] && echo "    repo:   ${team_repo[$team]}"
            echo "    since:  ${team_ts[$team]}"
        done
        echo ""
    fi

    if [[ ${#completed[@]} -gt 0 ]]; then
        echo "── Completed (not yet swept) ──"
        for team in "${completed[@]}"; do
            local label="$team"
            [[ -n "${team_project[$team]:-}" ]] && label="$team [${team_project[$team]}]"
            local exit_info="exit ${team_exit[$team]:-?}"
            echo "  $label — $exit_info"
            [[ -n "${team_branch[$team]:-}" ]] && echo "    branch: ${team_branch[$team]} (ready to merge)"
        done
        echo ""
    fi

    if [[ ${#attention[@]} -gt 0 ]]; then
        echo "── Needs Attention ──"
        for team in "${attention[@]}"; do
            local label="$team"
            [[ -n "${team_project[$team]:-}" ]] && label="$team [${team_project[$team]}]"
            echo "  $label — pane DEAD (no done event, may have crashed)"
            echo "    last seen: ${team_ts[$team]}"
        done
        echo ""
    fi

    if [[ ${#running[@]} -eq 0 && ${#completed[@]} -eq 0 && ${#attention[@]} -eq 0 ]]; then
        echo "  All teams resolved. Clean slate."
        echo ""
    fi

    # Pending merges: completed teams with branches
    local has_merges=0
    for team in "${completed[@]}"; do
        if [[ -n "${team_branch[$team]:-}" ]]; then
            if [[ $has_merges -eq 0 ]]; then
                echo "── Pending Merges ──"
                has_merges=1
            fi
            echo "  ${team_branch[$team]} → main  (team: $team)"
        fi
    done
    [[ $has_merges -eq 1 ]] && echo ""
}

cmd_merge() {
    local target="$1"

    # Find team info from ledger
    local repo="" branch="" worktree_path=""
    if [[ -f "$LEDGER" ]]; then
        # Get the last spawn event for this team
        local spawn_line
        spawn_line=$(grep "\"team\":\"${target}\"" "$LEDGER" | grep '"event":"team_spawn"' | tail -1)
        if [[ -n "$spawn_line" ]]; then
            repo=$(echo "$spawn_line" | sed -n 's/.*"repo":"\([^"]*\)".*/\1/p')
            branch=$(echo "$spawn_line" | sed -n 's/.*"branch":"\([^"]*\)".*/\1/p')
        fi
    fi

    if [[ -z "$branch" ]]; then
        echo "Error: no branch found for team '$target' in ledger" >&2
        echo "This command works with teams spawned with --worktree" >&2
        return 1
    fi

    if [[ -z "$repo" ]]; then
        echo "Error: no repo found for team '$target' in ledger" >&2
        return 1
    fi

    echo "Merging: $branch → main"
    echo "  repo: $repo"
    echo ""

    # Check if branch exists
    if ! git -C "$repo" rev-parse --verify "$branch" &>/dev/null; then
        echo "Error: branch '$branch' not found in $repo" >&2
        return 1
    fi

    # Check for uncommitted changes on main
    if ! git -C "$repo" diff --quiet 2>/dev/null; then
        echo "Warning: uncommitted changes in $repo" >&2
        echo "Please commit or stash before merging." >&2
        return 1
    fi

    # Attempt merge
    local current_branch
    current_branch=$(git -C "$repo" branch --show-current)

    if [[ "$current_branch" != "main" && "$current_branch" != "master" ]]; then
        echo "Switching to ${current_branch:-main}..."
        git -C "$repo" checkout main 2>/dev/null || git -C "$repo" checkout master 2>/dev/null || {
            echo "Error: could not switch to main branch" >&2
            return 1
        }
    fi

    if git -C "$repo" merge "$branch" --no-edit 2>&1; then
        echo ""
        echo "Merged $branch into $(git -C "$repo" branch --show-current)"
        ledger_append "team_merged" "$target" ',"branch":"'"$(json_escape "$branch")"'"'

        # Clean up worktree
        local worktree_dir="${repo}/.worktrees/${target}"
        if [[ -d "$worktree_dir" ]]; then
            git -C "$repo" worktree remove "$worktree_dir" --force 2>/dev/null && \
                echo "Removed worktree: $worktree_dir"
        fi

        # Delete the feature branch
        git -C "$repo" branch -d "$branch" 2>/dev/null && \
            echo "Deleted branch: $branch"
    else
        echo ""
        echo "CONFLICT: merge failed. Resolve manually or abort with:"
        echo "  git -C $repo merge --abort"
        return 1
    fi
}

case "${1:-help}" in
    list) require_tmux; cmd_list ;;
    capture)
        [[ -z "${2:-}" ]] && { echo "Usage: station capture <team-name>" >&2; exit 1; }
        require_tmux; cmd_capture "$2"
        ;;
    capture-all) require_tmux; cmd_capture_all ;;
    status) cmd_status "${2:-}" ;;
    sweep) cmd_sweep ;;
    kill)
        [[ -z "${2:-}" ]] && { echo "Usage: station kill <team-name>" >&2; exit 1; }
        require_tmux; cmd_kill "$2"
        ;;
    cleanup)
        [[ -z "${2:-}" ]] && { echo "Usage: station cleanup <team-name>" >&2; exit 1; }
        require_tmux; cmd_cleanup "$2"
        ;;
    worktrees)
        cmd_worktrees "${2:-.}"
        ;;
    layout) require_tmux; cmd_layout ;;
    registry)
        if [[ "${2:-}" == "--resolve" ]]; then
            [[ -z "${3:-}" ]] && { echo "Usage: station registry --resolve <name>" >&2; exit 1; }
            cmd_registry "$3"
        else
            cmd_registry
        fi
        ;;
    dashboard) cmd_dashboard ;;
    resume) cmd_resume ;;
    merge)
        [[ -z "${2:-}" ]] && { echo "Usage: station merge <team-name>" >&2; exit 1; }
        cmd_merge "$2"
        ;;
    *)
        echo "Usage: station <command>"
        echo ""
        echo "Commands:"
        echo "  list                      List all windows and panes"
        echo "  capture <name>            Capture a team lead's screen"
        echo "  capture-all               Capture all team lead screens"
        echo "  status [name]             Check team completion status"
        echo "  resume                    Session resume — what happened while you were away"
        echo "  sweep                     Clean up all completed teams"
        echo "  merge <name>              Merge a team's worktree branch into main"
        echo "  kill <name>               Kill team window + mirror pane"
        echo "  cleanup <name>            Kill team + remove git worktree"
        echo "  worktrees <path>          List git worktrees for a repo"
        echo "  layout                    Re-tile dashboard panes"
        echo "  registry                  List all projects and repos from station.toml"
        echo "  registry --resolve <name> Resolve project/tag to repo paths"
        echo "  dashboard                 Combined overview (registry + teams + journal)"
        ;;
esac
